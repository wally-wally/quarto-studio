# Postgres (Phase 1+)
DATABASE_URL=postgres://quarto:quarto@localhost:5432/quarto_studio
# 렌더 타임아웃(ms)
QUARTO_RENDER_TIMEOUT_MS=60000
# 렌더된 HTML 아티팩트 저장 디렉토리(웹·워커 공유). 기본 ./data/artifacts
ARTIFACT_DIR=./data/artifacts
# 첨부 문서(docx/pptx/pdf) 텍스트 추출 사이드카 URL (로컬 기본값)
CONVERT_SERVICE_URL=http://localhost:8000
# Daytona 렌더 백엔드 (키는 절대 커밋 금지 — .env.local에만 저장)
DAYTONA_API_KEY=
# 렌더용 Daytona 스냅샷 이름 (scripts/daytona-snapshot.sh로 생성)
DAYTONA_SNAPSHOT=quarto-render-1
